{
  "name": "dreamer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --out-dir dist",
    "dev": "tsx src/cli.ts run",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "dream": "tsx src/cli.ts run",
    "dream:schedule": "tsx src/cli.ts schedule --once",
    "eval:copilot-sdk": "tsx scripts/run-copilot-sdk-eval.ts"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.3.0",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
