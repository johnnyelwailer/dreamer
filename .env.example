# Copy this file to .env.local and fill values locally.
# .env.local is gitignored.

# Default runtime manifest uses BYOK OpenAI-compatible provider mode.
HOSTED_LLM_BASE_URL=
HOSTED_LLM_API_KEY=

# Optional explicit Copilot SDK BYOK env vars (override HOSTED_* when set).
COPILOT_SDK_BASE_URL=
COPILOT_SDK_API_KEY=

# Optional model override.
COPILOT_SDK_MODEL=
COPILOT_SDK_MAX_CONTEXT_WINDOW_TOKENS=
COPILOT_SDK_MAX_PROMPT_TOKENS=
COPILOT_SDK_MAX_SUBAGENT_PARALLELISM=

# Optional GitHub auth env vars for non-BYOK modes.
GITHUB_TOKEN=
COPILOT_SDK_SESSION_GITHUB_TOKEN=

# Optional GitHub Enterprise host and SDK CLI overrides.
GITHUB_HOST=
COPILOT_SDK_CLI_PATH=
COPILOT_SDK_CLI_URL=

LOCAL_LLAMA_BASE_URL=http://localhost:8080/v1
LOCAL_LLAMA_API_KEY=sk-no-key-required
LOCAL_LLAMA_MODEL=llama-3.1-8b

# Optional Honcho memory backend settings.
HONCHO_API_KEY=
HONCHO_WORKSPACE_ID=dreamer
HONCHO_URL=
DREAM_HONCHO_API_KEY=
DREAM_HONCHO_WORKSPACE_ID=
DREAM_HONCHO_BASE_URL=
DREAM_HONCHO_ENVIRONMENT=

# Optional runtime plugin selection.
DREAM_PLUGIN_PATHS=
DREAM_ADAPTER_ID=
DREAM_BACKEND_ID=
# Comma-separated list. When set, saves the same memory records to every listed backend.
# Example: DREAM_BACKEND_IDS=backend.file.memory,backend.copilot.memory
DREAM_BACKEND_IDS=
DREAM_PROVIDER_ID=
DREAM_STAGE_ORDER=
DREAM_STAGE_IMPLEMENTATIONS=

# Ingest sanitized transcript events and recorded signal insights into Honcho after local signal extraction.
# Omit slot.consolidation from DREAM_STAGE_ORDER when Honcho should own post-signal memory processing.
# DREAM_STAGE_ORDER=slot.orientation,slot.signal,slot.documentation,slot.skills,slot.governance,slot.observability
# DREAM_STAGE_IMPLEMENTATIONS=slot.signal=impl.signal.local-honcho-ingest

# Ingest compact raw transcript sessions into Honcho without local signal extraction.
# DREAM_STAGE_ORDER=slot.orientation,slot.signal,slot.documentation,slot.skills,slot.governance,slot.observability
# DREAM_STAGE_IMPLEMENTATIONS=slot.signal=impl.signal.honcho-raw
