{
  "provider": {
    "id": "provider.copilot.sdk",
    "defaultModel": "qwen3.6-35b-a3b-q3",
    "sdk": {
      "authMode": "none",
      "providerMode": "byok",
      "requestTimeoutMs": 300000,
      "infiniteSessionsEnabled": true,
      "gitHubTokenEnvVar": "GITHUB_TOKEN",
      "sessionGitHubTokenEnvVar": "COPILOT_SDK_SESSION_GITHUB_TOKEN",
      "cliPathEnvVar": "COPILOT_SDK_CLI_PATH",
      "cliUrlEnvVar": "COPILOT_SDK_CLI_URL",
      "clientExtraEnvVars": [
        "GITHUB_HOST"
      ],
      "byok": {
        "type": "openai",
        "wireApi": "completions",
        "baseUrlEnvVar": "COPILOT_SDK_BASE_URL",
        "fallbackBaseUrlEnvVar": "HOSTED_LLM_BASE_URL",
        "apiKeyEnvVar": "COPILOT_SDK_API_KEY",
        "fallbackApiKeyEnvVar": "HOSTED_LLM_API_KEY"
      }
    }
  },
  "pipeline": {
    "stageOrder": [
      "stage.orientation",
      "stage.signal",
      "stage.consolidation",
      "stage.documentation",
      "stage.skills",
      "stage.governance",
      "stage.observability"
    ],
    "agentPacks": {
      "stage.signal": {
        "defaultAgent": {
          "excludedTools": [
            "record_insight"
          ]
        },
        "customAgents": [
          {
            "name": "behavior-analyst",
            "displayName": "Behavior Analyst",
            "description": "Extracts communication, collaboration, pushback, clarification, and trust/frustration signals.",
            "tools": [
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/signal/agents/behavior-analyst.md",
            "infer": true
          },
          {
            "name": "architecture-analyst",
            "displayName": "Architecture Analyst",
            "description": "Extracts repository conventions, feature decisions, technical constraints, and future edit obligations.",
            "tools": [
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/signal/agents/architecture-analyst.md",
            "infer": true
          },
          {
            "name": "evidence-auditor",
            "displayName": "Evidence Auditor",
            "description": "Validates candidate insights against transcript evidence and rejects vague or overbroad memories.",
            "tools": [
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/signal/agents/evidence-auditor.md",
            "infer": true
          },
          {
            "name": "insight-recorder",
            "displayName": "Insight Recorder",
            "description": "Writes only approved durable insights through record_insight.",
            "tools": [
              "record_insight"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/signal/agents/insight-recorder.md",
            "infer": false
          }
        ],
        "execution": {
          "mode": "inferred"
        }
      }
    }
  },
  "docs": {
    "outputRootPath": "docs/generated",
    "fallbackOutputPath": "docs/generated/DREAM_OUTPUT.md",
    "promptTemplatePath": ".dreamer/config/prompts/docs-generation.md",
    "improvementHintsPath": ".dreamer/config/prompts/docs-improvement-hints.md",
    "maxSignals": 25,
    "maxMemories": 25,
    "maxEvents": 25
  },
  "eval": {
    "reportPath": "reports/evals/copilot-sdk-eval.json",
    "requestTimeoutMs": 300000,
    "maxAttempts": 3,
    "quality": {
      "reportPath": "reports/evals/dream-quality-eval.json",
      "selfImproveReportPath": "reports/evals/dream-self-improve.json",
      "minPassingScore": 0.8,
      "maxHintsToPersist": 8
    }
  },
  "discovery": {
    "copilotDebug": {
      "mode": "append",
      "searchPaths": []
    },
    "claudeCode": {
      "mode": "append",
      "searchPaths": []
    },
    "codexTrace": {
      "mode": "append",
      "searchPaths": []
    }
  }
}
