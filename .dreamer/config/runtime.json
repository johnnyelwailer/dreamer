{
  "provider": {
    "id": "provider.copilot.sdk",
    "defaultModel": "qwen3.6-35b-a3b-q3",
    "sdk": {
      "authMode": "none",
      "providerMode": "byok",
      "requestTimeoutMs": 300000,
      "infiniteSessionsEnabled": true,
      "gitHubTokenEnvVar": "GITHUB_TOKEN",
      "sessionGitHubTokenEnvVar": "COPILOT_SDK_SESSION_GITHUB_TOKEN",
      "cliPathEnvVar": "COPILOT_SDK_CLI_PATH",
      "cliUrlEnvVar": "COPILOT_SDK_CLI_URL",
      "clientExtraEnvVars": [
        "GITHUB_HOST"
      ],
      "byok": {
        "type": "openai",
        "wireApi": "completions",
        "baseUrlEnvVar": "COPILOT_SDK_BASE_URL",
        "fallbackBaseUrlEnvVar": "HOSTED_LLM_BASE_URL",
        "apiKeyEnvVar": "COPILOT_SDK_API_KEY",
        "fallbackApiKeyEnvVar": "HOSTED_LLM_API_KEY"
      }
    }
  },
  "pipeline": {
    "stageOrder": [
      "stage.orientation",
      "stage.signal",
      "stage.consolidation",
      "stage.documentation",
      "stage.skills",
      "stage.governance",
      "stage.observability"
    ],
    "agentPacks": {
      "stage.signal": {
        "defaultAgent": {
          "excludedTools": [
            "read_file",
            "get_message_details",
            "bash",
            "read_bash",
            "view",
            "grep_search",
            "file_search",
            "semantic_search",
            "list_dir",
            "run_in_terminal",
            "send_to_terminal",
            "get_terminal_output",
            "terminal_last_command"
          ]
        },
        "customAgents": [
          {
            "name": "behavior-analyst",
            "displayName": "Behavior Analyst",
            "description": "Extracts communication, collaboration, pushback, clarification, and trust/frustration signals.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/signal/agents/behavior-analyst.md",
            "infer": true
          },
          {
            "name": "architecture-analyst",
            "displayName": "Architecture Analyst",
            "description": "Extracts repository conventions, feature decisions, technical constraints, and future edit obligations.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/signal/agents/architecture-analyst.md",
            "infer": true
          },
          {
            "name": "failure-analyst",
            "displayName": "Failure Analyst",
            "description": "Extracts durable lessons from agent failures, tool misuse, eval regressions, and debugging corrections.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/signal/agents/failure-analyst.md",
            "infer": true
          }
        ]
      },
      "stage.consolidation": {
        "defaultAgent": {
          "excludedTools": [
            "list_memories",
            "read_reference",
            "bash",
            "read_bash",
            "view",
            "grep_search",
            "file_search",
            "semantic_search",
            "list_dir",
            "run_in_terminal",
            "send_to_terminal",
            "get_terminal_output",
            "terminal_last_command"
          ]
        },
        "customAgents": [
          {
            "name": "memory-inventory-reviewer",
            "displayName": "Memory Inventory Reviewer",
            "description": "Summarizes existing memories and flags duplicates, over-specific entries, and broad rules needing cleanup.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "list_memories",
              "read_reference"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/consolidation/agents/memory-inventory-reviewer.md",
            "infer": true
          },
          {
            "name": "contradiction-scope-reviewer",
            "displayName": "Contradiction Scope Reviewer",
            "description": "Classifies conflicts as true conflicts, conditional compatibility, overgeneralized memories, or stale rules.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "list_memories",
              "read_reference"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/consolidation/agents/contradiction-scope-reviewer.md",
            "infer": true
          },
          {
            "name": "reference-validator",
            "displayName": "Reference Validator",
            "description": "Validates cited references for risky memory writes/removals and reports evidence quality to the main agent.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "list_memories",
              "read_reference"
            ],
            "promptTemplatePath": ".dreamer/config/prompts/stages/consolidation/agents/reference-validator.md",
            "infer": true
          }
        ]
      }
    }
  },
  "docs": {
    "outputRootPath": "docs/generated",
    "fallbackOutputPath": "docs/generated/DREAM_OUTPUT.md",
    "promptTemplatePath": ".dreamer/config/prompts/docs-generation.md",
    "improvementHintsPath": ".dreamer/config/prompts/docs-improvement-hints.md",
    "maxSignals": 25,
    "maxMemories": 25,
    "maxEvents": 25
  },
  "eval": {
    "reportPath": "reports/evals/copilot-sdk-eval.json",
    "requestTimeoutMs": 300000,
    "maxAttempts": 3,
    "quality": {
      "reportPath": "reports/evals/dream-quality-eval.json",
      "selfImproveReportPath": "reports/evals/dream-self-improve.json",
      "minPassingScore": 0.8,
      "maxHintsToPersist": 8
    }
  },
  "discovery": {
    "copilotDebug": {
      "mode": "append",
      "searchPaths": []
    },
    "claudeCode": {
      "mode": "append",
      "searchPaths": []
    },
    "codexTrace": {
      "mode": "append",
      "searchPaths": []
    }
  }
}
