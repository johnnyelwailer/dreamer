{
  "provider": {
    "id": "provider.copilot.sdk",
    "defaultModel": "gpt-4o",
    "sdk": {
      "authMode": "none",
      "providerMode": "byok",
      "requestTimeoutMs": 300000,
      "infiniteSessionsEnabled": true,
      "gitHubTokenEnvVar": "GITHUB_TOKEN",
      "sessionGitHubTokenEnvVar": "COPILOT_SDK_SESSION_GITHUB_TOKEN",
      "cliPathEnvVar": "COPILOT_SDK_CLI_PATH",
      "cliUrlEnvVar": "COPILOT_SDK_CLI_URL",
      "clientExtraEnvVars": ["GITHUB_HOST"],
      "byok": {
        "type": "openai",
        "wireApi": "completions",
        "baseUrlEnvVar": "COPILOT_SDK_BASE_URL",
        "fallbackBaseUrlEnvVar": "HOSTED_LLM_BASE_URL",
        "apiKeyEnvVar": "COPILOT_SDK_API_KEY",
        "fallbackApiKeyEnvVar": "HOSTED_LLM_API_KEY"
      }
    }
  },
  "pipeline": {
    "stageOrder": [
      "stage.orientation",
      "stage.signal",
      "stage.consolidation",
      "stage.documentation",
      "stage.skills",
      "stage.governance",
      "stage.observability"
    ],
    "agentPacks": {
      "stage.signal": {
        "defaultAgent": {
          "allowedTools": [
            "task",
            "delegate",
            "list_agents",
            "manage_todo_list",
            "record_insight",
            "finalize_signal_extraction"
          ]
        },
        "customAgents": [
          {
            "name": "behavior-analyst",
            "displayName": "Behavior Analyst",
            "description": "Extracts communication, collaboration, pushback, clarification, and trust/frustration signals.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": "prompts/stages/signal/agents/behavior-analyst.md",
            "infer": true
          },
          {
            "name": "architecture-analyst",
            "displayName": "Architecture Analyst",
            "description": "Extracts repository conventions, feature decisions, technical constraints, and future edit obligations.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": "prompts/stages/signal/agents/architecture-analyst.md",
            "infer": true
          },
          {
            "name": "failure-analyst",
            "displayName": "Failure Analyst",
            "description": "Extracts durable lessons from agent failures, tool misuse, eval regressions, and debugging corrections.",
            "tools": [
              "bash",
              "read_bash",
              "view",
              "read_file",
              "get_message_details"
            ],
            "promptTemplatePath": "prompts/stages/signal/agents/failure-analyst.md",
            "infer": true
          }
        ],
        "execution": {
          "mode": "explicit-sequence",
          "explicitSequence": [
            "behavior-analyst",
            "architecture-analyst",
            "failure-analyst"
          ]
        }
      },
      "stage.consolidation": {
        "defaultAgent": {
          "allowedTools": [
            "task",
            "delegate",
            "list_agents",
            "manage_todo_list",
            "list_memories",
            "write_workspace_memory",
            "write_global_memory",
            "remove_memory",
            "finalize_consolidation"
          ]
        },
        "customAgents": [
          {
            "name": "memory-inventory-reviewer",
            "displayName": "Memory Inventory Reviewer",
            "description": "Summarizes existing memories and flags duplicates, over-specific entries, and broad rules needing cleanup.",
            "tools": ["view", "list_memories", "read_reference"],
            "promptTemplatePath": "prompts/stages/consolidation/agents/memory-inventory-reviewer.md",
            "infer": true
          },
          {
            "name": "contradiction-scope-reviewer",
            "displayName": "Contradiction Scope Reviewer",
            "description": "Classifies conflicts as true conflicts, conditional compatibility, overgeneralized memories, or stale rules.",
            "tools": ["view", "list_memories", "read_reference"],
            "promptTemplatePath": "prompts/stages/consolidation/agents/contradiction-scope-reviewer.md",
            "infer": true
          },
          {
            "name": "reference-validator",
            "displayName": "Reference Validator",
            "description": "Validates cited references for risky memory writes/removals and reports evidence quality to the main agent.",
            "tools": ["view", "list_memories", "read_reference"],
            "promptTemplatePath": "prompts/stages/consolidation/agents/reference-validator.md",
            "infer": true
          },
          {
            "name": "global-rule-extractor",
            "displayName": "Global Rule Extractor",
            "description": "Finds only broadly generalizable user-scope rules and filters out workspace-local patterns.",
            "tools": ["view", "list_memories", "read_reference"],
            "promptTemplatePath": "prompts/stages/consolidation/agents/global-rule-extractor.md",
            "infer": true
          }
        ],
        "execution": {
          "mode": "explicit-sequence",
          "explicitSequence": [
            "memory-inventory-reviewer",
            "contradiction-scope-reviewer",
            "reference-validator"
          ]
        }
      }
    }
  },
  "docs": {
    "outputRootPath": "docs/generated",
    "fallbackOutputPath": "docs/generated/DREAM_OUTPUT.md",
    "maxSignals": 25,
    "maxMemories": 25,
    "maxEvents": 25
  },
  "eval": {
    "reportPath": "reports/evals/copilot-sdk-eval.json",
    "requestTimeoutMs": 300000,
    "maxAttempts": 3,
    "quality": {
      "reportPath": "reports/evals/dream-quality-eval.json",
      "selfImproveReportPath": "reports/evals/dream-self-improve.json",
      "minPassingScore": 0.8,
      "maxHintsToPersist": 8
    }
  },
  "discovery": {
    "copilotDebug": {
      "mode": "append",
      "searchPaths": []
    },
    "claudeCode": {
      "mode": "append",
      "searchPaths": []
    },
    "codexTrace": {
      "mode": "append",
      "searchPaths": []
    }
  }
}
